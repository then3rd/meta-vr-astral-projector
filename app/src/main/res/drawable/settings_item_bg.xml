<?xml version="1.0" encoding="utf-8"?>
<!-- Background for focusable settings items. Shows a slightly lighter grayscale shade when
     hovered (pointer/hand-ray), focused (controller/D-pad nav) or pressed, so interaction is
     visible without any color. Falls back to the dark scrim otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#B3FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="#73FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#73FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#59000000" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>
