<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@android:color/black">

    <!-- LEFT camera slot -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <com.jiangdg.ausbc.widget.AspectRatioTextureView
            android:id="@+id/textureLeft"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/statusLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/status_scrim"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="@string/status_waiting"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </FrameLayout>

    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/divider" />

    <!-- RIGHT camera slot -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <com.jiangdg.ausbc.widget.AspectRatioTextureView
            android:id="@+id/textureRight"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/statusRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/status_scrim"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="@string/status_waiting"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </FrameLayout>

</LinearLayout>
