<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AstralProjector" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <!-- Transparent window so panel pixels outside the video panes stay alpha=0; combined
             with PanelConfigOptions.enableTransparent those areas render as passthrough. -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
